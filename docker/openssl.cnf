# Minimal OpenSSL configuration that always activates the default provider.
#
# opc-plc ships as a self-contained .NET app whose Linux crypto delegates to the
# system OpenSSL. On FIPS-enabled hosts the active OpenSSL FIPS provider rejects
# SHA-1, and the OPC UA startup certificate uses a SHA-1 thumbprint
# (X509Certificate.GetCertHashString). That first crypto call fails with
# "error:0308010C:digital envelope routines::unsupported" and the process aborts
# (exit 139), crash-looping the container.
#
# Pointing OPENSSL_CONF at this file (see Dockerfile) forces the default provider,
# where the SHA-1 digest is available, so certificate creation works regardless of
# the host FIPS state. Note: opc-plc is a test/simulator tool; this makes the image
# FIPS-tolerant, not FIPS-validated.
openssl_conf = openssl_init

[openssl_init]
providers = provider_sect

[provider_sect]
default = default_sect

[default_sect]
activate = 1
