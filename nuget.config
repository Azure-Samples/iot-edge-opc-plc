<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="opcua-preview" value="https://opcfoundation.pkgs.visualstudio.com/opcua-netstandard/_packaging/opcua-preview/nuget/v3/index.json" />
  </packageSources>

  <!--
    Package source mapping is required when using Central Package Management with
    multiple feeds (otherwise restore fails with NU1507).
    OPC Foundation packages may be pulled from either nuget.org (released) or
    opcua-preview (preview builds); everything else comes from nuget.org only.
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="opcua-preview">
      <package pattern="OPCFoundation.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
